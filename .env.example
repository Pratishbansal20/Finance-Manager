# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Auth.js � generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Access lockdown � only this Google email may sign in
OWNER_EMAIL="you@gmail.com"

# Field encryption � generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# Pricing � hours before cached prices are considered stale (default 24)
PRICE_STALE_HOURS="24"

# Cron � shared secret the daily price-refresh job must present (Vercel Cron
# sends it automatically). Generate like AUTH_SECRET.
CRON_SECRET=""
